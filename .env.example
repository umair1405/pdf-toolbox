# ── Database ──────────────────────────────
POSTGRES_USER=pdftoolbox
POSTGRES_PASSWORD=change_me
POSTGRES_DB=pdftoolbox
DATABASE_URL=postgresql+psycopg2://pdftoolbox:change_me@postgres:5432/pdftoolbox

# ── Redis / Celery ────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Auth ──────────────────────────────────
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Storage ───────────────────────────────
STORAGE_BACKEND=local            # local | s3
STORAGE_PATH=/app/storage
# S3-compatible (if STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# ── App ───────────────────────────────────
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
MAX_UPLOAD_SIZE_MB=100

# ── Frontend (Vercel project env vars) ────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
